<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="450.0" prefWidth="600.0" spacing="20.0" style="-fx-background-color: #0d1117; -fx-font-family: 'Segoe UI Semibold', sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nhom13.bidding.view.ResultUIController">

    <Label style="-fx-text-fill: #00d2ff; -fx-effect: dropshadow(one-pass-box, #00d2ff, 15, 0, 0, 0);" text="🏆 TỔNG KẾT PHIÊN ĐẤU GIÁ 🏆">
        <font><Font name="System Bold" size="28.0" /></font>
    </Label>

    <VBox alignment="CENTER" prefWidth="450.0" spacing="15.0" style="-fx-background-color: rgba(0, 210, 255, 0.05); -fx-padding: 30; -fx-background-radius: 15; -fx-border-color: #00d2ff; -fx-border-width: 1.5; -fx-border-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0, 210, 255, 0.4), 20, 0, 0, 0); -fx-max-width: 450;">

        <Label fx:id="productLabel" style="-fx-text-fill: #bdc3c7;" text="Sản phẩm: ...">
            <font><Font size="18.0" /></font>
        </Label>

        <Label fx:id="winnerLabel" style="-fx-text-fill: #2ecc71; -fx-effect: dropshadow(one-pass-box, #2ecc71, 10, 0, 0, 0);" text="Người thắng: ...">
            <font><Font name="System Bold" size="26.0" /></font>
        </Label>

        <Label fx:id="priceLabel" style="-fx-text-fill: #f1c40f; -fx-effect: dropshadow(one-pass-box, #f1c40f, 10, 0, 0, 0);" text="Mức giá chốt: 0 $">
            <font><Font name="System Bold" size="24.0" /></font>
        </Label>

    </VBox>

    <Label style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;" text="[ HỆ THỐNG ĐÃ NGẮT KẾT NỐI ]">
        <font><Font name="System Italic" size="14.0" /></font>
        <VBox.margin><Insets top="20.0" /></VBox.margin>
    </Label>
</VBox>