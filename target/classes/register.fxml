<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" prefWidth="400.0" prefHeight="500.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nhom13.bidding.controller.RegisterUIController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>
    <children>
        <Label text="ĐĂNG KÝ TÀI KHOẢN" textFill="#002d62">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </Label>

        <GridPane vgap="10.0" hgap="10.0">
            <children>
                <Label text="Tên đăng nhập:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtUsername" promptText="Nhập tên đăng nhập" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250.0" />

                <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="txtEmail" promptText="Nhập địa chỉ email" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Mật khẩu:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Nhập lại MK:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <PasswordField fx:id="txtConfirmPassword" promptText="Xác nhận mật khẩu" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            </children>
        </GridPane>

        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleRegisterClick" text="Đăng Ký" style="-fx-background-color: #002d62;" textFill="white">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Button>

        <Hyperlink onAction="#handleBackToLogin" text="Đã có tài khoản? Đăng nhập ngay" textFill="#64748b" />
    </children>
</VBox>