<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="650.0" spacing="20.0" style="-fx-background-color: #0d1117; -fx-font-family: 'Segoe UI Semibold', sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nhom13.bidding.view.AuctionUIController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <VBox alignment="CENTER" prefWidth="550.0" spacing="10.0" style="-fx-background-color: rgba(0, 210, 255, 0.05); -fx-border-color: #00d2ff; -fx-border-width: 1.5; -fx-border-radius: 12; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0, 210, 255, 0.4), 20, 0, 0, 0);">
        <padding>
            <Insets bottom="20.0" top="20.0" />
        </padding>

        <Label fx:id="productNameLabel" style="-fx-text-fill: #00d2ff; -fx-effect: dropshadow(one-pass-box, #00d2ff, 10, 0, 0, 0);" text="LONG HUYẾT KIẾM">
            <font><Font name="System Bold" size="32.0" /></font>
        </Label>

        <Label fx:id="productDescLabel" text="Cổ vật quý hiếm từ thời nhà Lê" textFill="#bdc3c7" />

        <Label fx:id="currentPriceLabel" style="-fx-text-fill: #f1c40f; -fx-effect: dropshadow(one-pass-box, #f1c40f, 5, 0, 0, 0);" text="5000 $">
            <font><Font name="System Bold" size="42.0" /></font>
        </Label>

        <Label fx:id="winnerLabel" text="TOP 1: Hữu Bằng" textFill="#2ecc71">
            <font><Font name="System Bold" size="16.0" /></font>
        </Label>
        <Label fx:id="timeLabel" text="⏳ CÒN LẠI: 30 GIÂY" textFill="#e74c3c">
            <font><Font name="System Bold" size="18.0" /></font>
        </Label>
    </VBox>

    <HBox alignment="CENTER" spacing="60.0">
        <VBox alignment="CENTER">
            <Label text="👤 HỮU BẰNG" textFill="#ecf0f1" />
            <Label fx:id="user1BalanceLabel" text="Ví: 10000 $" textFill="#00d2ff">
                <font><Font name="System Bold" size="20.0" /></font>
            </Label>
        </VBox>
        <VBox alignment="CENTER">
            <Label text="👤 HOÀNG" textFill="#ecf0f1" />
            <Label fx:id="user2BalanceLabel" text="Ví: 8000 $" textFill="#00d2ff">
                <font><Font name="System Bold" size="20.0" /></font>
            </Label>
        </VBox>
    </HBox>

    <HBox alignment="CENTER" spacing="15.0">
        <TextField fx:id="bidInput" prefWidth="180.0" promptText="NHẬP MỨC GIÁ..." style="-fx-background-color: rgba(255, 255, 255, 0.05); -fx-text-fill: white; -fx-border-color: #00d2ff; -fx-border-width: 0 0 1 0;" />

        <Button mnemonicParsing="false" onAction="#handleBidUser1" prefWidth="120.0" style="-fx-background-color: transparent; -fx-border-color: #00d2ff; -fx-text-fill: #00d2ff; -fx-border-width: 1; -fx-border-radius: 5; -fx-cursor: hand;" text="BẰNG ĐẶT">
            <font><Font name="System Bold" size="12.0" /></font>
        </Button>

        <Button mnemonicParsing="false" onAction="#handleBidUser2" prefWidth="120.0" style="-fx-background-color: transparent; -fx-border-color: #00d2ff; -fx-text-fill: #00d2ff; -fx-border-width: 1; -fx-border-radius: 5; -fx-cursor: hand;" text="HOÀNG ĐẶT">
            <font><Font name="System Bold" size="12.0" /></font>
        </Button>
    </HBox>

    <Label fx:id="messageLabel" text="Hệ thống trực tuyến - Sẵn sàng nhận lệnh" textFill="#7f8c8d" />
</VBox>