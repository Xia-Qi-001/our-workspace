<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox alignment="CENTER" spacing="15.0" prefHeight="400.0" prefWidth="600.0" style="-fx-padding: 20;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.nhom13.bidding.controller.AuctionUIController">

    <Label text="PHÒNG ĐẤU GIÁ TRỰC TIẾP" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <VBox alignment="CENTER" spacing="10.0" style="-fx-border-color: gray; -fx-padding: 15;">
        <Label fx:id="lblProductName" text="Tên sản phẩm" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <HBox alignment="CENTER" spacing="10.0">
            <Label text="Giá hiện hành:"/>
            <Label fx:id="lblCurrentPrice" text="0 VNĐ" style="-fx-text-fill: red; -fx-font-weight: bold; -fx-font-size: 16px;"/>
        </HBox>
        <HBox alignment="CENTER" spacing="10.0">
            <Label text="Đếm ngược:"/>
            <Label fx:id="lblEndTime" text="00:00:00" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
        </HBox>
    </VBox>

    <HBox alignment="CENTER" spacing="10.0">
        <Label text="Nhập giá Bid:"/>
        <TextField fx:id="txtBidAmount" promptText="Điền số tiền..."/>
        <Button text="Đặt Giá" onAction="#handlePlaceBid" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>

    <Button text="Quay lại Chợ" onAction="#handleBackToHome" style="-fx-margin-top: 20;"/>
</VBox>