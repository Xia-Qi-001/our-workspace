<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="450.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nhom13.bidding.controller.AuctionController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #002d62; -fx-padding: 10;">
            <children>
                <Button mnemonicParsing="false" onAction="#handleBackToHome" style="-fx-background-color: white; -fx-text-fill: #002d62;" text="&lt; Quay lại Chợ">
                    <font> <Font name="System Bold" size="12.0" /> </font>
                </Button>
                <Label text="PHÒNG ĐẤU GIÁ TRỰC TIẾP" textFill="WHITE">
                    <font> <Font name="System Bold" size="18.0" /> </font>
                </Label>
            </children>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20.0" style="-fx-padding: 30;">
            <children>
                <Label text="Vật phẩm đang đấu giá:">
                    <font> <Font size="14.0" /> </font>
                </Label>

                <Label fx:id="lblProductName" text="[Tên vật phẩm]" textFill="#002d62">
                    <font> <Font name="System Bold" size="26.0" /> </font>
                </Label>

                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label text="Giá cao nhất hiện tại:">
                            <font> <Font size="16.0" /> </font>
                        </Label>
                        <Label fx:id="lblCurrentPrice" text="0 VNĐ" textFill="#e63946">
                            <font> <Font name="System Bold" size="22.0" /> </font>
                        </Label>
                    </children>
                </HBox>

                <VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #f1f5f9; -fx-padding: 20; -fx-background-radius: 10;">
                    <children>
                        <Label text="Nhập mức giá bạn muốn trả (VNĐ):">
                            <font> <Font name="System Bold" size="14.0" /> </font>
                        </Label>
                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <TextField fx:id="txtBidAmount" prefHeight="35.0" prefWidth="250.0" promptText="Ví dụ: 15500000" />
                                <Button mnemonicParsing="false" onAction="#handlePlaceBid" prefHeight="35.0" style="-fx-background-color: #22c55e; -fx-text-fill: white;" text="ĐẶT GIÁ NGAY">
                                    <font> <Font name="System Bold" size="14.0" /> </font>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>